# === 하네스 기본 .gitignore (다언어) ===
# 실 프로젝트 적용 시 스택에 맞게 가감하세요.

# --- Secrets / 환경 ---
.env
.env.*
!.env.example
*.key
*.pem
credentials.json
secrets.*

# --- Claude Code 로컬 설정/런타임 (공유 금지) ---
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/*.lock

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/

# --- Node / JS / TS ---
node_modules/
.npm/
.pnpm-store/
.next/
.turbo/
out/
*.tsbuildinfo
coverage/

# --- Java / JVM ---
target/
.gradle/
*.class

# --- IDE / 에디터 ---
.idea/
.vscode/
*.swp
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- 로그 / 임시 ---
*.log
tmp/
.tmp/
